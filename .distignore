# Files excluded from the wp.org build. Sizer is fully self-contained with no
# runtime composer dependencies, so /vendor (dev-only tooling) is excluded; the
# bundled PSR-4 autoloader in autoload.php loads every class.
/vendor
/.git
/.github
/.gitignore
/.distignore
/.wp-env.json
/.wp-env.override.json
/node_modules
/tests
/scripts
/docs
/composer.json
/composer.lock
/package.json
/package-lock.json
/phpcs.xml.dist
/phpstan.neon.dist
/phpstan-baseline.neon
/playwright.config.ts
/tsconfig.json
/vite.config.ts
/README.md
/SPEC.md
/.DS_Store

.DS_Store
/.wordpress-org
/test-results
/playwright-report
/.playwright-mcp
