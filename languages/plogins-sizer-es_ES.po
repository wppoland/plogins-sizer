#. Plugin Name of the plugin
#: sizer.php
msgid "Sizer - Size Guide and Charts for WooCommerce"
msgstr "Sizer - Guía de tallas y tablas para WooCommerce"

#. Plugin URI of the plugin
#: sizer.php
msgid "https://plogins.com/sizer/"
msgstr "https://plogins.com/es/sizer/"

#. Description of the plugin
#: sizer.php
msgid ""
"Add size guides and size charts to your WooCommerce products via an "
"accessible modal."
msgstr ""
"Añade guías de tallas y tablas de tallas a sus productos WooCommerce a "
"través de una ventana modal accesible."

#. Author of the plugin
#: sizer.php
msgid "WPPoland"
msgstr "WPPoland"

#. Author URI of the plugin
#: sizer.php
msgid "https://plogins.com/"
msgstr "https://plogins.com/"

#: sizer.php:55
msgid ""
"Sizer - Size Guide and Charts for WooCommerce requires WooCommerce to be "
"active."
msgstr ""
"Sizer: guía de tallas y gráficos para WooCommerce requiere que WooCommerce "
"esté activo."

#: src/Admin/Assignment.php:42 src/Admin/SettingsPage.php:122
#: src/Admin/SettingsPage.php:137 src/Service/Settings.php:46
msgid "Size guide"
msgstr "Guía de tallas"

#: src/Admin/Assignment.php:65 src/Admin/SettingsPage.php:330
